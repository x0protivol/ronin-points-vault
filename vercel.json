{
  "version": 2,
  "name": "ronin-points-vault",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_CHAIN_ID": "2021",
    "NEXT_PUBLIC_RPC_URL": "https://saigon-testnet.roninchain.com/rpc"
  },
  "github": {
    "enabled": true,
    "autoAlias": true
  }
}
