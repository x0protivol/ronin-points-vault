# ============================================
# Ronin Points Vault - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git

# ---- Deployer Wallet ----
# Your deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ---- Ronin RPC Endpoints ----
# Ronin Testnet (Saigon)
RONIN_TESTNET_RPC=https://saigon-testnet.roninchain.com/rpc

# Ronin Mainnet
RONIN_MAINNET_RPC=https://api.roninchain.com/rpc

# ---- Contract Addresses (filled after deployment) ----
POINTS_VAULT_ADDRESS=
AXIE_ADAPTER_ADDRESS=
PIXELS_ADAPTER_ADDRESS=
WILD_FOREST_ADAPTER_ADDRESS=

# ---- Fee Recipient Wallet ----
FEE_RECIPIENT_ADDRESS=your_fee_recipient_wallet_here

# ---- Backend Indexer ----
INDEXER_PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/points_vault

# ---- Game API Keys (for indexer adapters) ----
AXIE_API_KEY=
PIXELS_API_KEY=
WILD_FOREST_API_KEY=

# ---- Explorer API (for contract verification) ----
RONIN_EXPLORER_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_CHAIN_ID=2021
NEXT_PUBLIC_POINTS_VAULT_ADDRESS=
NEXT_PUBLIC_RONIN_RPC=https://saigon-testnet.roninchain.com/rpc
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001
